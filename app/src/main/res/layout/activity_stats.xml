<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:padding="12dp"
    tools:context=".ui.StatsActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dashboard Diario"
            android:textColor="@color/text_neon"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="@drawable/card_neon">

                <TextView
                    android:id="@+id/tvCardKm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0 km"
                    android:textColor="@color/text_neon"
                    android:textSize="22sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="KM totales"
                    android:textColor="@color/text_muted" />
            </LinearLayout>

            <Space
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="@drawable/card_neon">

                <TextView
                    android:id="@+id/tvCardTiempo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="00:00:00"
                    android:textColor="@color/text_neon"
                    android:textSize="22sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tiempo trabajado"
                    android:textColor="@color/text_muted" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="@drawable/card_neon">

                <TextView
                    android:id="@+id/tvCardBruta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0 Bs"
                    android:textColor="@color/text_neon"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ganancia bruta"
                    android:textColor="@color/text_muted" />
            </LinearLayout>

            <Space android:layout_width="8dp" android:layout_height="1dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="@drawable/card_neon">

                <TextView
                    android:id="@+id/tvCardGas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0 Bs"
                    android:textColor="@color/text_neon"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Gasolina"
                    android:textColor="@color/text_muted" />
            </LinearLayout>

            <Space android:layout_width="8dp" android:layout_height="1dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="@drawable/card_neon">

                <TextView
                    android:id="@+id/tvCardNeta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0 Bs"
                    android:textColor="@color/neon_green"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ganancia neta"
                    android:textColor="@color/text_muted" />
            </LinearLayout>
        </LinearLayout>

        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/chartNetos"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/card_neon"/>
    </LinearLayout>
</ScrollView>
